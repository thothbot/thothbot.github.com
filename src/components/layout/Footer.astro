---
import Section from './Section.astro';
import SocialLink from '../ui/SocialLink.astro';
import NameSvg from '../common/NameSvg.astro';

const socialLinks = [
  { icon: 'email', href: 'mailto:thothbot@gmail.com', label: 'Email' },
  { icon: 'github', href: 'https://github.com/thothbot', label: 'GitHub' },
];

const quotes = [
  "Most of my best ideas start with 'this is probably a bad idea, but…'",
  "I speak fluent stack trace.",
  "Every 'quick fix' is a small lie I tell myself.",
  "Half the job is convincing the computer I'm serious.",
  "AI helped build this site. I'll never tell which parts.",
  "Give me a whiteboard and I'll hand you back a new obsession.",
  "Refactoring: breaking working code, but with confidence.",
  "I collect edge cases the way other people collect regrets.",
  "Still convinced the next side project is the one.",
  "Prototype Friday, doubt it Monday, ship it Wednesday.",
  "The demo gods are fickle. Build accordingly.",
  "My rubber duck has seen some things.",
];

const timeline = [
  { year: '2012', label: '3D & WebGL', description: 'Parallax library' },
  { year: '2014', label: 'Cloud Editors', description: 'Graphic design tools at scale' },
  { year: '2016', label: 'Trading & ML', description: 'Crypto platform, neural networks' },
  { year: '2019', label: 'Architecture', description: 'AI/ML infrastructure, GPU clusters' },
  { year: '2023', label: 'AI Agents', description: 'LLM pipelines, RAG systems' },
];

const trackColors = ['#3b82f6', '#7c5cf0', '#a855f7', '#d6459b', '#ff2d55'];
const lastIndex = timeline.length - 1;
---

<Section id="footer" mobileAuto>
  <div class="relative z-10 h-full flex flex-col max-w-5xl mx-auto px-4 sm:px-6 pt-8 md:pt-16 lg:pt-20 pb-[calc(4rem_+_env(safe-area-inset-bottom))]">

    <div class="flex-1 flex flex-col justify-center gap-8 md:gap-12 py-4">

    <div class="text-center">
      <h2 class="mb-4"><NameSvg size="footer" class="mx-auto" /></h2>
      <p class="text-xl text-white/60">Software architect, happiest when I'm building</p>
    </div>

    <div class="hidden md:block md:py-6">
      <p class="text-center text-xs text-white/40 uppercase tracking-[0.25em] mb-10">The road so far</p>

      <div class="relative">
        <div class="journey-rail absolute top-[6px] left-[10%] right-[10%] h-px"></div>

        <div class="grid grid-cols-5 gap-3">
          {timeline.map((item, i) => (
            <div class="timeline-item text-center">
              <span
                class:list={['journey-node mx-auto mb-5', i === lastIndex && 'is-now']}
                style={`--c:${trackColors[i]}`}
              ></span>
              <span class="font-mono text-sm block mb-1" style={`color:${trackColors[i]}`}>{item.year}</span>
              <h4 class="text-white font-medium text-sm mb-1">{item.label}</h4>
              <p class="text-white/40 text-xs leading-relaxed">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="md:hidden h-14 overflow-hidden flex items-center justify-center">
      <div id="journey-ticker" class="journey-ticker text-center px-4">
        <div class="flex items-center justify-center gap-2">
          <span id="jt-dot" class="journey-node shrink-0"></span>
          <span id="jt-year" class="font-mono text-sm"></span>
          <span id="jt-label" class="text-white font-medium text-sm"></span>
        </div>
        <p id="jt-desc" class="text-white/40 text-xs mt-1"></p>
      </div>
    </div>

    <div class="text-center">
      <p class="max-w-2xl md:max-w-none mx-auto text-white/50 text-base leading-relaxed mb-6">
        I build AI systems and the platforms that hold them up, usually from the first sketch all the way to production. Lately that's a lot of multi-agent setups, RAG pipelines, and LLM products.
        <span class="mx-2 font-bold text-white/40">•</span>
        Most of my work happens in fast-moving startups, where I get to make the calls and actually ship. Before AI ate everything, I spent years on distributed systems and cloud plumbing (AWS, Kubernetes, the usual suspects).
      </p>

      <p class="text-white/70 text-lg mb-4">Got a project, a half-formed idea, or just want to say hi? My inbox is open.</p>

      <div class="flex justify-center gap-4">
        {socialLinks.map((link) => (
          <SocialLink {...link} />
        ))}
      </div>
    </div>

    </div>

    <div class="border-t border-white/10 pt-6 text-center">
      <p class="text-white/50 text-sm font-mono tracking-wide mb-1">{new Date().getFullYear()}</p>
      <p id="random-quote" class="quote-text text-violet-400/70 text-sm italic"></p>
    </div>
  </div>
</Section>

<script define:vars={{ quotes }}>
  const quoteEl = document.getElementById('random-quote');
  if (quoteEl) {
    let currentIndex = Math.floor(Math.random() * quotes.length);
    quoteEl.textContent = quotes[currentIndex];

    setInterval(() => {
      quoteEl.style.opacity = '0';
      quoteEl.style.transform = 'translateX(-10px)';

      setTimeout(() => {
        currentIndex = (currentIndex + 1) % quotes.length;
        quoteEl.textContent = quotes[currentIndex];
        quoteEl.style.transform = 'translateX(10px)';

        requestAnimationFrame(() => {
          quoteEl.style.opacity = '1';
          quoteEl.style.transform = 'translateX(0)';
        });
      }, 300);
    }, 5000);
  }
</script>

<script define:vars={{ timeline, trackColors }}>
  const ticker = document.getElementById('journey-ticker');
  if (ticker) {
    const dot = document.getElementById('jt-dot');
    const yearEl = document.getElementById('jt-year');
    const labelEl = document.getElementById('jt-label');
    const descEl = document.getElementById('jt-desc');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const render = (idx) => {
      const item = timeline[idx];
      const color = trackColors[idx];
      dot.style.setProperty('--c', color);
      yearEl.textContent = item.year;
      yearEl.style.color = color;
      labelEl.textContent = item.label;
      descEl.textContent = item.description;
    };

    let i = reduce ? timeline.length - 1 : 0;
    render(i);

    if (!reduce) {
      setInterval(() => {
        ticker.style.opacity = '0';
        ticker.style.transform = 'translateY(-14px)';

        setTimeout(() => {
          i = (i + 1) % timeline.length;
          render(i);
          ticker.style.transform = 'translateY(14px)';

          requestAnimationFrame(() => {
            ticker.style.opacity = '1';
            ticker.style.transform = 'translateY(0)';
          });
        }, 320);
      }, 3200);
    }
  }
</script>

<style>
  .timeline-item {
    opacity: 0;
    animation: fadeIn 0.5s ease-out forwards;
  }

  .timeline-item:nth-child(1) { animation-delay: 0.1s; }
  .timeline-item:nth-child(2) { animation-delay: 0.15s; }
  .timeline-item:nth-child(3) { animation-delay: 0.2s; }
  .timeline-item:nth-child(4) { animation-delay: 0.25s; }
  .timeline-item:nth-child(5) { animation-delay: 0.3s; }
  .timeline-item:nth-child(6) { animation-delay: 0.35s; }

  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  .journey-node {
    display: block;
    width: 14px;
    height: 14px;
    border-radius: 9999px;
    background: var(--c);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--c) 16%, transparent),
      0 0 12px 1px color-mix(in srgb, var(--c) 55%, transparent);
  }

  .journey-node.is-now {
    animation: nowPulse 2.4s ease-in-out infinite;
  }

  @keyframes nowPulse {
    0%, 100% {
      box-shadow:
        0 0 0 4px color-mix(in srgb, var(--c) 16%, transparent),
        0 0 12px 1px color-mix(in srgb, var(--c) 55%, transparent);
    }
    50% {
      box-shadow:
        0 0 0 7px color-mix(in srgb, var(--c) 10%, transparent),
        0 0 22px 4px color-mix(in srgb, var(--c) 75%, transparent);
    }
  }

  .journey-rail {
    transform-origin: left;
    background: linear-gradient(90deg, #3b82f6, #8b5cf6, #ff2d55);
    animation: railDraw 1.1s ease-out both;
  }

  @keyframes railDraw {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .quote-text {
    display: inline-block;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .journey-ticker {
    transition: opacity 0.32s ease, transform 0.32s ease;
  }
</style>
